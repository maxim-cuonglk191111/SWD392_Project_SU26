# ============================================================
#  .env.example — Template để các thành viên biết cần set gì
#  FILE NÀY ĐƯỢC COMMIT LÊN GIT — KHÔNG CHỨA GIÁ TRỊ THẬT
# ============================================================

# --- Agora RTC Credentials ---
# Đăng ký và lấy tại: https://console.agora.io/
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# --- JWT Secret (tối thiểu 32 ký tự, dùng cho signing identity tokens) ---
# Dùng: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret_here_minimum_32_chars
