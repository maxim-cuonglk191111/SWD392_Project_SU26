generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  username    String   @unique
  displayName String
  avatarId    Int      @default(1)
  role        String   @default("LUCY")
  bio         String?
  xp          Int      @default(0)
  coin        Int      @default(100)
  isAnonymous Boolean  @default(true)
  isBanned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hostedRooms        Room[]
  participations     RoomParticipant[]
  messages           Message[]
  sentGifts          UserGift[] @relation("Sender")
  receivedGifts      UserGift[] @relation("Receiver")
  podcasts           Podcast[]
  progress           UserProgress[]
  walletTransactions WalletTransaction[]
  documents          UploadedDocument[]
}

model Level {
  id          String   @id @default(uuid())
  language    String
  stage       String
  levelNumber Int
  title       String
  titleZh     String?
  titleJp     String?
  description String?
  duration    Int      @default(60)
  subLevels   String   @default("[]")
  createdAt   DateTime @default(now())

  rooms    Room[]
  progress UserProgress[]
}

model Room {
  id                String    @id @default(uuid())
  title             String
  description       String?
  levelId           String?
  hostId            String
  language          String    @default("EN")
  maxParticipants    Int       @default(50)
  currentCount      Int       @default(0)
  status            String    @default("WAITING")
  stage             String    @default("BEGINNER")
  currentSubLevel   Int       @default(0)
  isLocked          Boolean   @default(false)
  isRecording       Boolean   @default(false)
  pinnedDocumentId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  endedAt           DateTime?

  level        Level?             @relation(fields: [levelId], references: [id])
  host         User               @relation(fields: [hostId], references: [id])
  participants RoomParticipant[]
  messages     Message[]
  gifts        UserGift[]
  podcast      Podcast?
}

model RoomParticipant {
  id         String    @id @default(uuid())
  roomId     String
  userId     String
  joinedAt   DateTime  @default(now())
  leftAt     DateTime?
  handRaised Boolean   @default(false)
  isMuted    Boolean   @default(true)
  isSpeaker  Boolean   @default(false)
  role       String    @default("LISTENER")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
}

model Message {
  id        String   @id @default(uuid())
  roomId    String
  userId    String?
  content   String
  type      String   @default("TEXT")
  createdAt DateTime @default(now())

  room Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
}

model Gift {
  id        String   @id @default(uuid())
  name      String   @unique
  emoji     String
  coinCost  Int
  imageUrl  String?
  createdAt DateTime @default(now())

  userGifts UserGift[]
}

model UserGift {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  giftId     String
  roomId     String?
  createdAt  DateTime @default(now())

  sender   User  @relation("Sender", fields: [senderId], references: [id])
  receiver User  @relation("Receiver", fields: [receiverId], references: [id])
  gift     Gift  @relation(fields: [giftId], references: [id])
  room     Room? @relation(fields: [roomId], references: [id])
}

model Podcast {
  id          String   @id @default(uuid())
  roomId      String   @unique
  hostId      String
  title       String
  description String?
  audioUrl    String?
  duration    Int      @default(0)
  viewCount   Int      @default(0)
  isPremium   Boolean  @default(false)
  price       Int      @default(0)
  status      String   @default("RECORDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id])
  host User @relation(fields: [hostId], references: [id])
}

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  levelId     String
  status      String    @default("LOCKED")
  score       Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  level Level @relation(fields: [levelId], references: [id])

  @@unique([userId, levelId])
}

model WalletTransaction {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Int
  balance   Int
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UploadedDocument {
  id            String   @id @default(uuid())
  originalName  String
  filePath      String
  fileType      String
  language      String?
  parsedLevels  String   @default("[]")
  uploadedBy    String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  uploadedByUser User @relation(fields: [uploadedBy], references: [id])
}
